#%Module 1.0
#
#  dorado module for use with 'environment-modules' package:
#
setenv DORADO_MODELS_DIRECTORY  /opt/bioit/dorado/2.0.0/models
prepend-path  PATH              /opt/bioit/dorado/2.0.0/dorado-2.0.0-linux-x64/bin
prepend-path  LD_LIBRARY_PATH   /opt/bioit/dorado/2.0.0/dorado-2.0.0-linux-x64/lib
